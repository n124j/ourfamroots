# ============================================================
#  OurFamRoots backend — standalone / outside-Docker config
#  Used by pydantic-settings when running the API directly
#  (python -m uvicorn src.main:app) without Docker Compose.
#
#  When running via Docker Compose all values are injected
#  through docker-compose.yml environment: blocks instead.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=OurFamRoots
DEBUG=false
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:7000/ourfamroots

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:7001/0

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=changeme-replace-with-openssl-rand-hex-64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:7006"]
CORS_ALLOW_CREDENTIALS=true

# ── S3 / MinIO ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme
AWS_REGION=us-east-1
S3_BUCKET=ourfamroots-local
S3_ENDPOINT_URL=http://localhost:7002
S3_PUBLIC_URL=http://localhost:7002

# ── Public URLs ──────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
DEFAULT_TENANT_SLUG=ourfamroots-system

# ── Gmail SMTP ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ourfamroots.app

# ── OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=60

# ── Email verification ──────────────────────────────────────
# Auto-verify new users on registration (skip email verification).
# Set to true for development/testing; always false in production.
AUTO_VERIFY_EMAIL=true

# ── Super Admin ──────────────────────────────────────────────
# Email address of the Super Administrator — this user gets
# full visibility over all trees/users and can toggle
# maintenance mode. Leave blank to disable.
SUPER_ADMIN_EMAIL=

# ── Sentry (optional) ────────────────────────────────────────
SENTRY_DSN=

# ============================================================
#  OurFamRoots — Docker Compose environment
#  Copy this file to .env and fill in the required values.
#
#  cp .env.example .env
#
#  Values with no default are REQUIRED and must be set before
#  running `docker compose up -d`.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=ourfamroots
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme           # REQUIRED

# ── MinIO (local S3-compatible storage) ──────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme         # REQUIRED

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=changeme-replace-with-openssl-rand-hex-64    # REQUIRED

# ── Gmail SMTP ───────────────────────────────────────────────
# Use a Gmail App Password — not your account password.
# Setup: Google Account → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com       # REQUIRED
SMTP_PASSWORD=your-app-password      # REQUIRED
EMAIL_FROM=your-email@gmail.com      # REQUIRED

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=DEBUG                      # DEBUG | INFO | WARNING | ERROR
DEFAULT_TENANT_SLUG=ourfamroots-system

# ── Public URLs ──────────────────────────────────────────────
# Change all three when deploying behind a Cloudflare Tunnel or custom domain.
#
# VITE_API_BASE_URL — URL the BROWSER uses to reach the API.
#   Baked into the frontend bundle at Vite start time.
#   Local:   http://localhost:7004/api/v1
#   Tunnel:  https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:7004/api/v1

# API_BASE_URL — Used by the backend to build OAuth callback redirect URIs.
#   Must be the externally reachable API root (no /api/v1 suffix).
#   Local:   http://localhost:7004
#   Tunnel:  https://api.yourdomain.com
API_BASE_URL=http://localhost:7004

# FRONTEND_BASE_URL — Embedded in verification and password-reset emails.
#   Local:   http://localhost:7006
#   Tunnel:  https://yourdomain.com
FRONTEND_BASE_URL=http://localhost:7006

# ── CORS ─────────────────────────────────────────────────────
# JSON array of origins allowed to call the API.
# Include localhost:5173 for local Playwright e2e tests.
# Add your tunnel / production domain when deploying.
CORS_ORIGINS=["http://localhost:5173","http://localhost:7006","http://localhost:7009"]

# ── Vite dev-server allowed hosts ────────────────────────────
# Comma-separated list of extra hostnames the Vite dev server accepts.
# Needed when proxying through Cloudflare Tunnel or a custom domain.
# Leave empty for local-only development.
#   Local:   (leave empty)
#   Tunnel:  VITE_ALLOWED_HOSTS=ourfamroots.com
VITE_ALLOWED_HOSTS=

# ── S3 / MinIO ───────────────────────────────────────────────
S3_BUCKET=ourfamroots-local
S3_REGION=us-east-1

# S3_ENDPOINT_URL — Internal Docker URL for MinIO; keep as-is for local dev.
#   Change only if pointing at a real S3 or external MinIO instance.
S3_ENDPOINT_URL=http://minio:9000

# S3_PUBLIC_URL — Browser-accessible URL for presigned download links.
#   Local:   http://localhost:7002
#   Tunnel:  https://s3.yourdomain.com
S3_PUBLIC_URL=http://localhost:7002

# ── Redis (internal Docker service URLs) ─────────────────────
# These use Docker's internal service name "redis".
# Change only if running Redis outside of Docker Compose.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Monitoring (only needed with docker-compose.monitoring.yml) ──
# Grafana admin credentials — use a strong password in any non-local environment.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme          # REQUIRED
GRAFANA_ROOT_URL=http://localhost:7009   # Change to your public URL in production
# Redis address for the redis-exporter (no database-index suffix, unlike REDIS_URL).
REDIS_ADDR=redis://redis:6379

# ── Email verification ──────────────────────────────────────
# Auto-verify new users on registration (skip email verification).
# Set to true for development/testing; always false in production.
AUTO_VERIFY_EMAIL=true

# ── Super Admin ─────────────────────────────────────────────
# Email address of the Super Administrator.
# This user gets full visibility over all trees/users and can
# toggle maintenance (Under Construction) mode.
SUPER_ADMIN_EMAIL=
